<Page
    x:Class="Baru_Client.Views.Pages.CameraPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Baru_Client.Views.Pages"
    xmlns:vm="clr-namespace:Baru_Client.ViewModels.Pages"
    xmlns:cameraCtrl="clr-namespace:Baru_Client.Camera"
    Title="CameraPage">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="전신이 카메라에 나오도록 해주세요" FontSize="16" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"/>
            <!-- 실시간 횟수 -->
            <TextBlock Text="횟수: " FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentCount}" FontSize="16" VerticalAlignment="Center"/>

            <Rectangle Width="1" Height="24" Fill="Gray" VerticalAlignment="Center" Margin="12,0"/>

            <!-- 실시간 정확도 -->
            <TextBlock Text="정확도: " FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentAccuracy, StringFormat={}{0}%}" FontSize="16" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <cameraCtrl:Camera_Control x:Name="cameraControl" Grid.Column="0" Visibility="Collapsed"/>

            <MediaElement x:Name="ExerciseVideo" Grid.Column="1" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" MediaEnded="ExerciseVideo_MediaEnded"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="스쿼트" Width="100" Height="36" Command="{Binding PlaySquatCommand}"/>
            <Button Content="런지" Width="100" Height="36" Command="{Binding PlayLungeCommand}"/>
            <Button Content="사이드 스트레칭" Width="120" Height="36" Command="{Binding PlaySideStretchCommand}"/>
            <Button Content="종료" Width="100" Height="36" Command="{Binding StopCommand}"/>
        </StackPanel>
    </Grid>
</Page>