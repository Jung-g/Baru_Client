<Page
    x:Class="Baru_Client.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    x:Name="DashboardRoot" Loaded="DashboardRoot_Loaded">

    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 타이틀과 날짜 -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,24">
            <ui:TextBlock
                Text="일일 운동 목표"
                FontSize="28" FontWeight="SemiBold"
                DockPanel.Dock="Left"/>
            <ui:TextBlock
                Text="{Binding TodayDateText}"
                FontSize="16" FontWeight="SemiBold"
                VerticalAlignment="Center"
                DockPanel.Dock="Right"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ExerciseGoals}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="28" Margin="0,0,0,24">
                            <StackPanel>
                                <!-- 운동명+아이콘+버튼 -->
                                <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <ui:SymbolIcon Symbol="HeartPulse20" FontSize="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ui:TextBlock Text="{Binding ExerciseName}" FontSize="20" FontWeight="Bold"/>
                                    </StackPanel>
                                    <ui:Button Content="목표 설정"
                                        Appearance="Primary"
                                        Command="{Binding ElementName=DashboardRoot, Path=DataContext.SetGoalCommand}"
                                        CommandParameter="{Binding}"
                                        MinWidth="90"
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"/>
                                </DockPanel>

                                <!-- 목표 입력 및 달성 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:TextBlock Text="목표 횟수:" FontWeight="SemiBold" FontSize="16"/>
                                    <ui:TextBox Text="{Binding GoalInputText, UpdateSourceTrigger=PropertyChanged}"
                                                Width="70" HorizontalAlignment="Left" Margin="8,0"/>
                                    <ui:TextBlock Text="현재 달성 횟수:" Margin="24,0,0,0" FontSize="16"/>
                                    <ui:TextBlock Text="{Binding CurrentCount}" Margin="8,0" FontSize="16"/>
                                </StackPanel>

                                <!-- 진행률 바와 퍼센트 -->
                                <Grid Margin="0,0,0,12" Height="26">
                                    <ProgressBar
                                        Value="{Binding ProgressBarValue, Mode=OneWay}"
                                        Minimum="0" Maximum="100"
                                        Height="25"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Background="#EEE"
                                        VerticalAlignment="Center"/>
                                    <ui:TextBlock
                                        Text="{Binding AchievementPercentage, StringFormat={}{0:F0}%}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="#444"
                                        FontSize="16"/>
                                </Grid>

                                <!-- 목표 횟수 표시 -->
                                <ui:TextBlock
                                    FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    HorizontalAlignment="Right">
                                    <Run Text="목표: "/>
                                    <Run Text="{Binding Goal, StringFormat={}{0:N0}}"/>
                                    <Run Text="회"/>
                                </ui:TextBlock>
                            </StackPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
