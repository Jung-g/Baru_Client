<Page
    x:Class="Baru_Client.Views.Pages.AnalysisChartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    Title="일일 분석">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TextBlock Grid.Row="0" Text="일별 동작 종류별 비율 분석"
           FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"/>

        <!-- 날짜 선택(DatePicker) -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="날짜 선택:" VerticalAlignment="Center" FontWeight="Bold"/>
            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Margin="10,0,0,0"/>
            <TextBlock Text="{Binding SelectedDateString}" Margin="20,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 파이 차트 -->
        <lvc:PieChart
            Grid.Row="2"
            Series="{Binding PieSeries}"
            LegendLocation="Right"
            Margin="0,10,0,0"
            DataContext="{Binding}">
        </lvc:PieChart>
    </Grid>
</Page>
