<ui:FluentWindow
    x:Class="Baru_Client.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    Title="{Binding ApplicationTitle, Mode=OneWay}"
    Width="1500" Height="1000"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    mc:Ignorable="d">

    <Grid>
        <!-- 타이틀바 -->
        <ui:TitleBar x:Name="TitleBar" Title="{Binding ApplicationTitle}" CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/wpfui-icon-256.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 네비게이션/메뉴 -->
        <ui:NavigationView
            x:Name="RootNavigation"
            Padding="42,0,42,0"
            MenuItemsSource="{Binding MenuItems, Mode=OneWay}"
            FooterMenuItemsSource="{Binding FooterMenuItems, Mode=OneWay}"
            IsBackButtonVisible="Visible"
            IsPaneToggleVisible="True"
            OpenPaneLength="310"
            PaneDisplayMode="Left"
            TitleBar="{Binding ElementName=TitleBar, Mode=OneWay}">
            
            <ui:NavigationView.Header>
                <ui:BreadcrumbBar x:Name="BreadcrumbBar" Margin="42,32,42,20" />
            </ui:NavigationView.Header>
            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <ui:SnackbarPresenter x:Name="SnackbarPresenter" />
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
