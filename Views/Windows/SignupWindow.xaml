<Window x:Class="Baru_Client.Views.Windows.SignupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        Title="회원가입"
        Height="420"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Text="회원가입" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- 입력 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="이름" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="35"/>

            <TextBlock Text="아이디" Margin="0,15,0,4"/>
            <TextBox Text="{Binding Userid, UpdateSourceTrigger=PropertyChanged}" Height="35"/>

            <TextBlock Text="비밀번호" Margin="0,15,0,4"/>
            <PasswordBox Height="35" PasswordChanged="SPasswordBox_PasswordChanged"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <ui:Button Content="가입" Width="100" Command="{Binding SignupCommand}" Margin="0,0,10,0"/>
                <ui:Button Content="닫기" Width="100" Click="Close_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- 스낵바 ( 알람 )-->
        <ui:SnackbarPresenter Grid.Row="1" x:Name="SnackBar"/>

        <!-- 하단 버전 -->
        <TextBlock Grid.Row="2" Text="v1.0.0" FontSize="10" Foreground="Gray" HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</Window>
